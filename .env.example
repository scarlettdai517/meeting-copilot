# 当前使用的模型提供商（与界面选择一致，可选：openai / anthropic / google / deepseek / zhipu / minicpm / moonshot）
LLM_PROVIDER=openai

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---------- Anthropic (Claude) ----------
# pip install anthropic
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---------- Google (Gemini) ----------
# pip install google-generativeai
GOOGLE_API_KEY=your-google-ai-key
GOOGLE_MODEL=gemini-1.5-flash

# ---------- DeepSeek (OpenAI 兼容) ----------
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------- 智谱 Zhipu (OpenAI 兼容) ----------
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_MODEL=glm-4-flash
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---------- 面壁 MiniCPM (OpenAI 兼容) ----------
MINICPM_API_KEY=your-minicpm-key
MINICPM_MODEL=minicpm
# MINICPM_BASE_URL=https://openapi.modelbest.cn/v1
# 若使用本地 vLLM OpenAI 兼容服务，可改为：
# MINICPM_BASE_URL=http://localhost:8000/v1

# ---------- 月之暗面 Moonshot/Kimi (OpenAI 兼容) ----------
MOONSHOT_API_KEY=your-moonshot-key
MOONSHOT_MODEL=moonshot-v1-8k
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 说明：Smart RAG 的语义检索（Embedding）目前使用 OpenAI API，若选用其他提供商生成文本，请保留 OPENAI_API_KEY 用于检索；或仅使用 OpenAI 时可不配置其他 key。
